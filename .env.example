# Database
# For Docker: use "postgres" as host (Docker service name)
# For local:  use "localhost" with port 5433
DATABASE_URL="postgresql://hris_user:hris_password@postgres:5432/hris_db"

# Redis
# For Docker: use "redis" as host (Docker service name)
# For local:  use "localhost"
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRATION=24h

# App
PORT=3001
FRONTEND_URL=http://localhost:3000

# Frontend (baked into client JS at build time)
NEXT_PUBLIC_API_URL=http://localhost:3001
